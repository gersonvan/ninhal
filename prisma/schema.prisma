// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Um Tenant corresponde a um criador (conta) e é a raiz de isolamento de dados.
/// Toda tabela de domínio (aves, ninhadas, ...) deve referenciar um Tenant via `tenantId`
/// e ser filtrada por ele através do middleware de isolamento (ver lib/tenant/).
model Tenant {
  id        String   @id @default(uuid())
  /// ID do usuário do Supabase Auth (auth.users.id) dono deste tenant.
  ownerId   String   @unique
  name      String?
  focus     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
