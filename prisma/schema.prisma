// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Um Tenant corresponde a um criador (conta) e é a raiz de isolamento de dados.
/// Toda tabela de domínio (aves, ninhadas, ...) deve referenciar um Tenant via `tenantId`
/// e ser filtrada por ele através do middleware de isolamento (ver lib/tenant/).
model Tenant {
  id                             String    @id @default(uuid())
  /// ID do usuário do Supabase Auth (auth.users.id) dono deste tenant.
  ownerId                        String    @unique
  name                           String?
  focus                          String?
  logoUrl                        String?
  /// Preferência: exibir alerta de consanguinidade ao formar um casal com parentesco próximo.
  alertasConsanguinidadeAtivados Boolean   @default(true)
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt
  aves                           Ave[]
  ninhadas                       Ninhada[]
}

/// Lista extensível de espécies (catálogo compartilhado, não isolado por tenant),
/// usada como opção de seleção no Cadastro Geral de aves.
model Especie {
  id   String @id @default(uuid())
  nome String @unique
  aves Ave[]
}

enum SexoAve {
  MACHO
  FEMEA
  NAO_SEXADO
}

enum OrigemAve {
  NASCIDA_NO_CRIATORIO
  ADQUIRIDA
}

enum StatusAve {
  ATIVO
  RESERVADO
  VENDIDO
  OBITO
  FUGIU
}

/// Cadastro Geral de aves do plantel. Tenant-scoped — registrada em
/// lib/tenant/scoped-models.ts para isolamento automático por criador.
model Ave {
  id             String    @id @default(uuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  /// Identificador físico da anilha, inserido manualmente pelo usuário — único por tenant, não globalmente.
  anilha         String
  nomeApelido    String?
  especieId      String
  especie        Especie   @relation(fields: [especieId], references: [id])
  mutacaoCor     String?
  sexo           SexoAve
  dataNascimento DateTime? @db.Date
  origem         OrigemAve
  /// Referencia outra Ave do mesmo tenant, mesma espécie, sexo Macho.
  anilhaPaiId    String?
  paiAve         Ave?      @relation("AvePai", fields: [anilhaPaiId], references: [id])
  filhosComoPai  Ave[]     @relation("AvePai")
  /// Referencia outra Ave do mesmo tenant, mesma espécie, sexo Fêmea.
  anilhaMaeId    String?
  maeAve         Ave?      @relation("AveMae", fields: [anilhaMaeId], references: [id])
  filhosComoMae  Ave[]     @relation("AveMae")
  status         StatusAve @default(ATIVO)
  foto           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  ninhadasComoMacho Ninhada[] @relation("NinhadaMacho")
  ninhadasComoFemea Ninhada[] @relation("NinhadaFemea")

  @@unique([tenantId, anilha])
}

/// Ninhada de um casal de aves do plantel. Tenant-scoped — registrada em
/// lib/tenant/scoped-models.ts para isolamento automático por criador.
model Ninhada {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  /// Código no formato AAAA-NN, gerado automaticamente (sequência por tenant/ano), editável pelo usuário.
  codNinhada       String
  anilhaMachoId    String
  macho            Ave      @relation("NinhadaMacho", fields: [anilhaMachoId], references: [id])
  anilhaFemeaId    String
  femea            Ave      @relation("NinhadaFemea", fields: [anilhaFemeaId], references: [id])
  dataPostura      DateTime @db.Date
  ovosPrevistos    Int?
  ovosBotados      Int?
  ovosFerteis      Int?
  filhotesNascidos Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, codNinhada])
}
